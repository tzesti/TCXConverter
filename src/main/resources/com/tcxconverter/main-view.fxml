<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tcxconverter.controller.MainController"
      onDragOver="#onDragOver"
      onDragDropped="#onDragDropped"
      onDragEntered="#onDragEntered"
      onDragExited="#onDragExited">

    <HBox spacing="10"
          style="-fx-padding: 8; -fx-alignment: center-left; -fx-background-color: #f0f0f0; -fx-border-color: #d0d0d0; -fx-border-width: 0 0 1 0;">
        <Label fx:id="statusLabel"
               text="Drop a .tcx file here to convert"
               style="-fx-font-size: 13;"
               HBox.hgrow="ALWAYS"
               maxWidth="Infinity"/>
        <Button fx:id="copyButton"
                text="Copy All"
                onAction="#onCopyClicked"/>
        <Button fx:id="saveButton"
                text="Save as .txt"
                onAction="#onSaveClicked"/>
    </HBox>

    <TextArea fx:id="outputTextArea"
              VBox.vgrow="ALWAYS"
              editable="false"
              wrapText="false"
              promptText="Drag and drop a .tcx file onto this window to convert it."
              onDragOver="#onDragOver"
              onDragDropped="#onDragDropped"
              onDragEntered="#onDragEntered"
              onDragExited="#onDragExited"
              style="-fx-font-family: 'Courier New'; -fx-font-size: 12;"/>
</VBox>
